generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  role                Role                 @default(OWNER)
  walletAddress       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  aadharHash          String?
  isKycVerified       Boolean              @default(false)
  kycVerifiedAt       DateTime?
  panHash             String?
  acquisitionRequests AcquisitionRequest[] @relation("AuthorityRequests")
  verifications       AcquisitionRequest[] @relation("VerifierActions")
  lands               Land[]
  landHistories       LandHistory[]
  notifications       Notification[]
}

model Land {
  id                  String               @id @default(cuid())
  landId              String               @unique
  ownerId             String
  area                Float
  location            String
  coordinates         Json?
  status              LandStatus           @default(AVAILABLE)
  txHash              String?
  docHash             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  acquisitionRequests AcquisitionRequest[]
  documents           Document[]
  owner               User                 @relation(fields: [ownerId], references: [id])
  histories           LandHistory[]
}

model AcquisitionRequest {
  id            String                @id @default(cuid())
  landId        String
  authorityId   String
  verifierId    String?
  status        String                @default("PENDING")
  paymentStatus PaymentStatus         @default(PENDING)
  amount        Float?
  verifierNote  String?
  txHash        String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  authority     User                  @relation("AuthorityRequests", fields: [authorityId], references: [id])
  land          Land                  @relation(fields: [landId], references: [id])
  verifier      User?                 @relation("VerifierActions", fields: [verifierId], references: [id])
  timeline      AcquisitionTimeline[]
}

model AcquisitionTimeline {
  id                   String             @id @default(cuid())
  acquisitionRequestId String
  action               String
  txHash               String?
  createdAt            DateTime           @default(now())
  acquisitionRequest   AcquisitionRequest @relation(fields: [acquisitionRequestId], references: [id])
}

model Document {
  id                String   @id @default(cuid())
  landId            String
  type              String
  fileName          String
  ipfsCid           String
  hash              String
  createdAt         DateTime @default(now())
  isOnChainVerified Boolean  @default(false)
  onChainTxHash     String?
  land              Land     @relation(fields: [landId], references: [id])
}

model LandHistory {
  id          String   @id @default(cuid())
  landId      String
  action      String
  performedBy String
  metadata    Json?
  createdAt   DateTime @default(now())
  land        Land     @relation(fields: [landId], references: [id])
  user        User     @relation(fields: [performedBy], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  landId    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum Role {
  OWNER
  AUTHORITY
  VERIFIER
}

enum LandStatus {
  AVAILABLE
  UNDER_ACQUISITION
  ACQUIRED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  LOCKED
  RELEASED
  CONFIRMING
  REFUNDED
}
